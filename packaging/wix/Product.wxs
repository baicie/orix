<?xml version="1.0" encoding="UTF-8"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Orix"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="baicie"
    UpgradeCode="B5C8E2A1-3D4F-6B7E-9A8C-1D2E3F4A5B6C">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      Platform="x64"
      Description="High-performance package manager compatible with pnpm" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Orix CLI" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathEnvironment" />
      <ComponentRef Id="ApplicationShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Icon Id="orix.exe" SourceFile="$(var.SourceDir)\orix.exe" />

    <Property Id="ARPPRODUCTICON" Value="orix.exe" />
    <Property Id="ARPHELPLINK" Value="https://github.com/baicie/orix" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/baicie/orix" />
    <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONROOT" />

    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="ProgramsFolder" Name="Programs">
          <Directory Id="APPLICATIONROOT" Name="Orix">
            <Directory Id="INSTALLFOLDER" Name="bin" />
          </Directory>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Orix" />
      </Directory>

      <Directory Id="DesktopFolder" />
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component
        Id="orix_exe"
        Guid="B5C8E2A1-3D4F-6B7E-9A8C-1D2E3F4A5B6D"
        Win64="yes">

        <File
          Id="orix_exe"
          Source="$(var.SourceDir)\orix.exe" />

        <RemoveFolder
          Id="CleanUpInstallFolder"
          Directory="INSTALLFOLDER"
          On="uninstall" />

        <RemoveFolder
          Id="CleanUpApplicationRoot"
          Directory="APPLICATIONROOT"
          On="uninstall" />

        <RemoveFolder
          Id="CleanUpProgramsFolder"
          Directory="ProgramsFolder"
          On="uninstall" />

        <RegistryValue
          Root="HKCU"
          Key="Software\baicie\orix"
          Name="InstallPath"
          Value="[INSTALLFOLDER]"
          Type="string"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component
        Id="PathEnvironment"
        Guid="B5C8E2A1-3D4F-6B7E-9A8C-1D2E3F4A5B70"
        Win64="yes">

        <Environment
          Id="AddOrixToPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="no" />

        <RegistryValue
          Root="HKCU"
          Key="Software\baicie\orix"
          Name="PathEnvironment"
          Value="1"
          Type="integer"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component
        Id="ApplicationShortcut"
        Guid="B5C8E2A1-3D4F-6B7E-9A8C-1D2E3F4A5B6E">

        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="Orix"
          Description="High-performance package manager compatible with pnpm"
          Target="[INSTALLFOLDER]orix.exe"
          WorkingDirectory="INSTALLFOLDER" />

        <RemoveFolder
          Id="CleanUpStartMenuFolder"
          Directory="ApplicationProgramsFolder"
          On="uninstall" />

        <RegistryValue
          Root="HKCU"
          Key="Software\baicie\orix"
          Name="StartMenuShortcuts"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="DesktopFolder">
      <Component
        Id="DesktopShortcut"
        Guid="B5C8E2A1-3D4F-6B7E-9A8C-1D2E3F4A5B6F">

        <Shortcut
          Id="DesktopShortcut"
          Name="Orix"
          Description="High-performance package manager compatible with pnpm"
          Target="[INSTALLFOLDER]orix.exe"
          WorkingDirectory="INSTALLFOLDER" />

        <RegistryValue
          Root="HKCU"
          Key="Software\baicie\orix"
          Name="DesktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
